# ═══════════════════════════════════════════════════════════════
#  ECom AI Dashboard V3.0 配置文件
# ═══════════════════════════════════════════════════════════════
#
#  新电脑 setup 只需两步:
#
#  1. 安装 Python 3.10+
#     winget install Python.Python.3.12
#     或者: https://www.python.org/downloads/
#     ⚠️ 安装时勾选 "Add Python to PATH"
#
#  2. 安装 Node.js 18+
#     winget install OpenJS.NodeJS.LTS
#     或者: https://nodejs.org/
#
#  3. 复制此文件为 .env 并填写 API Key（可选）
#     copy backend\.env.example backend\.env
#
#  4. 双击 启动.bat
#
# ═══════════════════════════════════════════════════════════════

# 调试模式
DEBUG=true
APP_NAME=ECom AI Dashboard
APP_VERSION=3.0.0

# 数据库（可选，不填则使用内置数据模拟器）
DATABASE_URL=postgresql+asyncpg://ecom:ecom2024@localhost:5432/ecom_dashboard

# Redis（可选）
REDIS_URL=redis://localhost:6379/0

# 密钥
SECRET_KEY=dev-secret-key-change-in-production

# 数据源: auto(自动) / kafka / generator
DATA_SOURCE=auto

# ═══════════════════════════════════════════════════════════════
#  LLM API Key（可选，不填则使用规则引擎模式）
#  通义千问: https://dashscope.console.aliyun.com/
#  OpenAI:   https://platform.openai.com/api-keys
# ═══════════════════════════════════════════════════════════════
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
DEEPSEEK_API_KEY=

# MCP Server
MCP_SERVER_ENABLED=true

# A2A 多智能体
A2A_ENABLED=true
A2A_TIMEOUT=3.0
DATA_AGENT_URL=http://localhost:8010
ANALYZE_AGENT_URL=http://localhost:8011
SENTIMENT_AGENT_URL=http://localhost:8012
REPORT_AGENT_URL=http://localhost:8013

# 安全护栏
GUARDRAILS_ENABLED=true
MAX_AUTO_BUDGET_ADJUST_PCT=20.0

# CORS（允许局域网访问）
CORS_ORIGINS=["*"]
